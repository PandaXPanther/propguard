# Alpaca API (paper trading by default)
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Account config
ACCOUNT_SIZE=50000          # Your starting account balance
PRESET=apex                 # apex | topstep | ftmo | custom
POLL_INTERVAL_SEC=30        # How often to check (seconds)
ALERT_COOLDOWN_MIN=15       # Min minutes between repeat alerts for same breach

# Only needed if PRESET=custom
# DAILY_LOSS_LIMIT_PCT=3
# MAX_DRAWDOWN_PCT=5
# PROFIT_TARGET_PCT=10
